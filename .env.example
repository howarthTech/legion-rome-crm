# legion-rome-crm — environment variables
#
# Copy to .env (gitignored) for local dev. In production these go into
# /srv/secrets/legion-rome-crm.env on the VPS (mode 600, root-owned) per the
# OPS hosting-pattern runbook.

# --- Server -------------------------------------------------------------------
# Loopback only in production — Caddy on the host reverse-proxies to this.
LISTEN_ADDR=127.0.0.1:8081

# Where SQLite stores its data file. The directory must be writable by the
# process. In Docker this is a named volume; locally, a relative path is fine.
DB_PATH=./data/crm.db

# Public URL the app is reachable at. Used to verify Twilio webhook signatures
# (Twilio HMACs the full URL it called). Get this wrong and webhooks 403.
PUBLIC_URL=https://admin.romelegion.org

# REQUIRED. The post's name — shown in page chrome and in every SMS body.
# Per-client; there is no default. A missing ORG_NAME aborts startup so a
# misconfigured container can't brand one post's messages with another's name.
ORG_NAME=American Legion Post 5


# --- Admin auth ---------------------------------------------------------------
# The single admin account allowed to log in.
ADMIN_USERNAME=admin

# bcrypt hash of the admin password. Generate with:
#   echo -n 'your-password' | htpasswd -niBC 10 admin | cut -d: -f2
# or
#   go run ./cmd/hash-password your-password
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_ME

# Random ≥32-char string used as the HMAC key for session cookies. Generate:
#   head -c 32 /dev/urandom | base64
# Rotate to invalidate every existing session.
SESSION_SECRET=REPLACE_ME_with_a_random_32_plus_char_string


# --- Twilio -------------------------------------------------------------------
# If any of these are empty, the SMS client runs in DRY RUN mode — sends are
# logged to stdout but not transmitted. Useful for local dev without a Twilio
# account.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164 format, e.g. +17065551234
TWILIO_FROM_NUMBER=
